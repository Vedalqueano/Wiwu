// WiWU Flow — Prisma Schema
// Baseado no documento de engenharia wiwu_flow_engenharia.pdf

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ── EMPRESA ────────────────────────────────────────
model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departments   Department[]
  users         User[]
  channels      Channel[]
  announcements Announcement[]
}

// ── DEPARTAMENTOS ──────────────────────────────────
model Department {
  id          String  @id @default(cuid())
  name        String
  slug        String
  description String?
  color       String  @default("#050A2D")
  icon        String?
  parentId    String?
  companyId   String

  company  Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent   Department? @relation("SubDepts", fields: [parentId], references: [id])
  children Department[] @relation("SubDepts")
  users    User[]
  channels Channel[]
  policies Policy[]
  schedules Schedule[]
  kpis     KPI[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, slug])
}

// ── USUÁRIOS ───────────────────────────────────────
enum UserRole {
  SUPER
  ADMIN
  MANAGER
  EMPLOYEE
  VIEWER
}

enum PresenceStatus {
  ONLINE
  AWAY
  OFFLINE
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  matricula     String?        @unique
  name          String
  initials      String
  passwordHash  String
  role          UserRole       @default(EMPLOYEE)
  avatar        String?
  color         String         @default("#050A2D")
  presence      PresenceStatus @default(OFFLINE)
  lastSeen      DateTime?
  companyId     String
  departmentId  String?
  onboarded     Boolean        @default(false)

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])

  messages       Message[]
  reactions      Reaction[]
  notifications  Notification[]
  tasksCreated   Task[]          @relation("TaskCreator")
  tasksAssigned  Task[]          @relation("TaskAssignee")
  channelMembers ChannelMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── CANAIS ─────────────────────────────────────────
enum ChannelType {
  PUBLIC
  DEPARTMENT
  PRIVATE
  DIRECT
  ANNOUNCEMENT
}

model Channel {
  id           String      @id @default(cuid())
  name         String
  slug         String
  description  String?
  type         ChannelType @default(PUBLIC)
  companyId    String
  departmentId String?

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])

  messages Message[]
  members  ChannelMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, slug])
}

model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  joinedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

// ── MENSAGENS ──────────────────────────────────────
model Message {
  id        String  @id @default(cuid())
  content   String
  channelId String
  userId    String
  parentId  String? // Thread / reply
  fileUrl   String?
  fileName  String?
  fileSize  String?

  channel  Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Message?  @relation("Thread", fields: [parentId], references: [id])
  replies  Message[] @relation("Thread")
  reactions Reaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reaction {
  id        String @id @default(cuid())
  emoji     String
  messageId String
  userId    String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
}

// ── NOTIFICAÇÕES ───────────────────────────────────
enum NotificationType {
  MENTION
  DIRECT_MESSAGE
  TASK_ASSIGNED
  TASK_DUE
  PROCESS_UPDATE
  SCHEDULE_PUBLISHED
  LOW_STOCK
  ANNOUNCEMENT
  SYSTEM
}

model Notification {
  id       String           @id @default(cuid())
  type     NotificationType
  title    String
  body     String
  read     Boolean          @default(false)
  metadata Json?
  userId   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ── PROCESSOS / KNOWLEDGE BASE ─────────────────────
model Policy {
  id           String  @id @default(cuid())
  title        String
  slug         String
  content      String  // Markdown
  version      Int     @default(1)
  published    Boolean @default(false)
  departmentId String

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── TAREFAS (KANBAN) ───────────────────────────────
enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  creatorId   String
  assigneeId  String?

  creator  User  @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee User? @relation("TaskAssignee", fields: [assigneeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── ESCALAS ────────────────────────────────────────
model Schedule {
  id           String @id @default(cuid())
  title        String
  departmentId String
  weekData     Json   // { "seg": "08:00-17:00", "ter": "08:00-17:00", ... }
  published    Boolean @default(false)

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── INVENTÁRIO ─────────────────────────────────────
model InventoryItem {
  id       String @id @default(cuid())
  sku      String @unique
  name     String
  category String
  quantity Int    @default(0)
  minimum  Int    @default(0)
  location String?

  movements InventoryMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

model InventoryMovement {
  id     String       @id @default(cuid())
  type   MovementType
  qty    Int
  reason String?
  itemId String

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ── KPIs ───────────────────────────────────────────
model KPI {
  id           String @id @default(cuid())
  name         String
  value        Float
  target       Float?
  unit         String? // "%", "R$", "un"
  departmentId String
  period       String  // "daily", "weekly", "monthly"

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── COMUNICADOS ────────────────────────────────────
model Announcement {
  id        String  @id @default(cuid())
  title     String
  content   String  // Markdown
  pinned    Boolean @default(false)
  global    Boolean @default(true)
  companyId String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
